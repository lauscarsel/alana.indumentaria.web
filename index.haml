- gallery_image = ["buzos-morley.jpg","buzos-urban.jpg","BuzosTommy.jpg","buzourban.png","campera-mujer.jpg","campera.jpg","camperapeluchebordo.jpg","Cargo Negro.jpg","cargo.jpg","cargobeige.jpg","cargomarron.jpg","CargoverdeMilitar.jpg","Chaleecocuero.jpg","chino3.png","chino4.png","chino5.png","chino6.jpg","chinoazul.jpg","chinonegro.jpg","Chombas.jpg","malla1.jpg","malla2.jpg","malla3.jpg","malla4.jpg","malla5.jpg","malla6.jpg","malla7.jpg","malla8.jpg","Mallas.jpg","MorleyML-marron.jpg","MorleyML-negra.jpg","MorleyML-rosa.jpg","MorleyML-verde.jpg","Musculosa Morley Rosa.jpg","Musculosa Morley Gris.jpg","Musculosa Morley Lila.jpg","Musculosa Morley Negra.jpg","Musculosa Morley Roja.jpg","Musculosa Morley.jpg","pantalon luminoso.jpg","pantalon-luminoso.jpg","pantalon-luminoso2.jpg","Pantalones Luminosos.jpg","remara morley Manga larga.jpg","remera estampada.jpg","Remera Mariposa.jpg","remera marron.jpg"]

%doctype html
%html{class:"no-js", lang:"es"}
  %head
    %meta{charset:"utf-8"}
    %title Alana Indumentaria
    %meta{name:"description", content:"Viste diferente, vestite bien"}
    %link{rel:"stylesheet", href:"css/normalize.css"}
    %link{rel:"stylesheet", href:"css/bootstrap.css"}
    %link{href:"https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&display=swap",rel:"stylesheet"}
    %link{rel:"stylesheet", href:"https://cdn.jsdelivr.net/flexboxgrid/6.3.1/flexboxgrid.min.css"}
    %link{rel:"stylesheet", href:"css/styles.css"}
    %meta{name:"viewport", content:"width=device-width, initial-scale=1"}
    %meta{:"data-name" =>"image-counter", content:"#{gallery_image.size-1}"}

  %body
    .video-container
      %video{autoplay:true, loop:true, muted:true, width:"1280", height:"720"}
        %source{src:"videos-fotos/mp4/ropa.mp4", type:"video/mp4"}
        %source{src:"videos-fotos/webm/ropa.webm", type:"video/webm"}

    .row.full-height.middle-xs.center-xs.relative.up#home
      .col-xs-12
        .box.white-text
          %img{src:"/logo/logo.png",width:200}
          %h1.dancing-script.title.no-margin Alana Indumentaria
          %p#is-open
            %i.glyphicon.glyphicon-time
            Compranos ahora 
      %nav.fixed.top.right.navigation#navigation
        - menu = ["Inicio","Menu","Galeria","Contacto"]
        %ul.list-inline
          - menu.each do |item|
            %li
              %a{}= item
      .absolute.black.large-padding.white-text.full-width#description
        .row.middle-xs.center-xs
          .col-xs-7.col-sm-6.white-text.medium
            VESTITE BIEN CON NOSOTROS
          .col-xs.hidden#sticky-navigation
            .box
            %nav.text-right.navigation
              %ul.list-inline
                - menu.each do |item|
                  %li
                    %a{}= item

  .text-center.relative#menu
    .absolute.white#menu-title
      %h2.dancing-script.title Productos
    - menu_photos = [{name:"mallas",image:"Mallas", pricing:"$10.000"},{name:"Chombas",image:"chombas", pricing:"$10.000"},{name:"Buzos Morley",image:"buzos-morley", pricing:"$10.000"},{name:"mallas",image:"Mallas", pricing:"$10.000"},{name:"Buzos Tommy",image:"BuzosTommy", pricing:"$10.000"},{name:"buzos urban",image:"buzos-urban", pricing:"$10.000"},{name:"buzos Ciudades",image:"buzos-ciudades", pricing:"$10.000"}]

    .row
      - menu_photos.each do |photo|
        .col-md-4.col-lg-3.col-sm-6.col-xs-12.clothes{style:"background-image:url(videos-fotos/imagenes/ropas/#{photo[:image]}.jpg)"}
          .screen
            .row.middle-xs.full-height
              .col-xs-12.white-text
                %h3.dancing-script.subtitle= photo[:name]
                %p.no-margin= photo[:pricing]
#gallery
  .inner
    - gallery_image.each do |image|
      .image{style:"background-image:url(videos-fotos/imagenes/ropas/#{image});"}


.container
  .card.white-text.black-text.text-center.relative
    %h3.medium.slim
      ALANA INDUMENTARIA
      %strong.dancing-script.medium VUSTE DIFERENTE, MARCA LA DIFERENCIA

.black.black-text.full-height#contact
  .row.center-xs
    .col-xs-12
      .box
        %form{action:"https://formspree.io/lautaroscarselletta1234@gmail.com",method:"POST",id:"contacto",class:"step-form"}
          .row
            .col-xs-2.col-md-1.text-center
              .box
                - 3.times do |i|
                  -if i ==0
                    .path-step.active
                  -else 
                    .path-step
                  %br
            .col-xs-5
              .box
                %fieldset.step.active
                  %input{type:"email",name:"email",placeholder:"Ingrese su email",class:"input",required: true}
                %fieldset.step  
                  %input{type:"text",name:"nombre",placeholder:"Ingrese su nombre",class:"input",required: true}
                %fieldset.step
                  %textarea{name:"body",placeholder:"En que podemos ayudarte?..",class:"input"}
                %div
                  %button{type:"submit",class:"btn btn-success"}
                    Enviar


%script{src:"https://code.jquery.com/jquery-4.0.0.min.js",
        integrity:"sha256-OaVG6prZf4v69dPg6PhVattBXkcOWQB62pdZ3ORyrao=",
        crossorigin:"anonymous"}
%script{src:"/js/form_object.js"}
%script{src:"js/main.js"}
%script{src:"js/dist/step.js"}

